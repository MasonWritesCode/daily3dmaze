# Postgres
POSTGRES_DB=daily3dmaze
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Application ports
WEB_PORT=3000
API_PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/daily3dmaze?sslmode=disable
APP_ENV=development
API_BASE_URL=http://localhost:8080
WEB_BASE_URL=http://localhost:3000
WEB_ALLOWED_ORIGINS=http://localhost:3000
TRUST_PROXY_HEADERS=false

# SMTP (optional in development, required in production for password reset emails)
SMTP_HOST=
SMTP_PORT=
SMTP_FROM_EMAIL=
SMTP_USERNAME=
SMTP_PASSWORD=

# OAuth
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_GITHUB_OAUTH_ENABLED=false
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false
NEXT_DEV_ALLOWED_ORIGINS=
